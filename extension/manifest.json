{
  "manifest_version": 3,
  "name": "Chrome Debugger MCP",
  "version": "1.0.0",
  "description": "Chrome extension bridge for chrome-debugger-mcp server",
  "minimum_chrome_version": "120",
  "permissions": [
    "tabs",
    "scripting",
    "cookies",
    "offscreen",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  }
}
